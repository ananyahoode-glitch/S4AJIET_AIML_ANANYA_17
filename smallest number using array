public class ReadArray {
    public static void main(String[] args) {
        int[] arr={10,35,60,25,88};
        int min=arr[0];
        for(int i=0;i<arr.length;i++){
            if(arr[i]<min){
                min=arr[i];
            }
        }
        System.out.println("The smallest number is:"+min);
    }
}
